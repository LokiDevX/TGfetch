{
  "name": "tgfetch",
  "version": "1.0.0",
  "description": "TGfetch – Premium Telegram Media Downloader",
  "main": "dist-electron/main.js",
  "author": {
    "name": "Lokesh Navale",
    "email": "youremail@example.com",
    "url": "https://www.linkedin.com/in/lokesh-navale/"
  },
  "homepage": "https://github.com/LokiDevX/TGfetch",
  "private": true,
  "scripts": {
    "dev": "concurrently \"vite\" \"npm run electron-dev\"",
    "electron-dev": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "build": "tsc --project tsconfig.electron.json && vite build",
    "build:electron": "npm run build && electron-builder --win --publish=never",
    "build:win": "npm run build && electron-builder --win",
    "build:linux": "npm run build && electron-builder --linux",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.344.0",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.22.0",
    "telegram": "^2.26.22",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.35",
    "tailwind-scrollbar": "^3.1.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.0",
    "vite": "^5.1.0",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.loki.tgfetch",
    "productName": "TGfetch by Loki",
    "copyright": "© 2026 Loki",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "artifactName": "TGfetch-by-Loki-Setup-${version}.exe"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    }
  }
}
